# Neon Postgres / Timescale
DATABASE_URL='postgresql://neondb_owner:npg_ZhQFwJlNnx17@ep-round-silence-a1gjjpu3-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require'
PG_POOL_MAX=15
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=10000
PG_QUERY_TIMEOUT_MS=15000
PG_STATEMENT_TIMEOUT_MS=15000
PG_APP_NAME=stock-sense-backend

# Auth
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=30
PASSWORD_RESET_SESSION_EXPIRES_MINUTES=15
EMAIL_VERIFICATION_OTP_EXPIRES_MINUTES=10
BCRYPT_SALT_ROUNDS=12
AUTH_EXPOSE_RESET_TOKEN=false
AUTH_EXPOSE_EMAIL_VERIFICATION_OTP=false
AUTH_REQUIRE_EMAIL_VERIFIED_FOR_LOGIN=false
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_MINUTES=15
AUTH_LOGIN_BLOCK_MINUTES=60
AUTH_MAX_ACTIVE_SESSIONS=5
GOOGLE_OAUTH_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Email delivery (auth + notifications)
EMAIL_DELIVERY_MODE=mock
EMAIL_PROVIDER=mock
EMAIL_FROM=Stock Sense <no-reply@example.com>
EMAIL_REPLY_TO=
EMAIL_WEBHOOK_URL=
RESEND_API_KEY=
AUTH_SEND_EMAIL_VERIFICATION_OTP=true
AUTH_SEND_PASSWORD_RESET_CODE=true
AUTH_LOGIN_ALERT_EMAIL_ENABLED=false

# Notification delivery scheduler
NOTIFICATION_DELIVERY_ENABLED=true
NOTIFICATION_DELIVERY_INTERVAL_MS=30000
NOTIFICATION_DELIVERY_RUN_ON_START=true
NOTIFICATION_DELIVERY_BATCH_SIZE=50
NOTIFICATION_EMAIL_MODE=mock
NOTIFICATION_EMAIL_PROVIDER=mock
NOTIFICATION_EMAIL_WEBHOOK_URL=
NOTIFICATION_PUSH_MODE=mock
NOTIFICATION_PUSH_PROVIDER=mock
NOTIFICATION_PUSH_WEBHOOK_URL=

# Market snapshot sync scheduler
MARKET_SYNC_ENABLED=true
MARKET_SYNC_INTERVAL_MS=60000
MARKET_SYNC_RUN_ON_START=true
MARKET_SYNC_STALE_AFTER_MS=180000

# WebSocket realtime server
WEBSOCKET_ENABLED=true
WEBSOCKET_PATH=/socket.io
WEBSOCKET_CORS_ORIGIN=*
WEBSOCKET_TRANSPORTS=websocket,polling
WEBSOCKET_PING_INTERVAL_MS=25000
WEBSOCKET_PING_TIMEOUT_MS=20000
WEBSOCKET_PERMESSAGE_DEFLATE_ENABLED=true
WEBSOCKET_PERMESSAGE_DEFLATE_THRESHOLD=1024
WEBSOCKET_MAX_CONNECTIONS=2000
WEBSOCKET_MAX_SUBSCRIPTIONS_PER_SOCKET=50
WEBSOCKET_CONNECT_RATE_LIMIT_WINDOW_MS=60000
WEBSOCKET_CONNECT_RATE_LIMIT_MAX=200
WEBSOCKET_REDIS_ADAPTER_ENABLED=true
WEBSOCKET_REDIS_URL=redis://localhost:6379
WEBSOCKET_INSTANCE_ID=stock-sense-local-1

# Live tick stream scheduler
LIVE_TICK_STREAM_ENABLED=true
LIVE_TICK_STREAM_INTERVAL_MS=15000
LIVE_TICK_STREAM_RUN_ON_START=true
LIVE_TICK_STREAM_PERSIST_TICKS=true
LIVE_TICK_STREAM_INCLUDE_DEFAULT_SYMBOLS=true
LIVE_TICK_STREAM_DEFAULT_SYMBOLS=RELIANCE,TCS,INFY,HDFCBANK,ICICIBANK
LIVE_TICK_STREAM_MAX_SYMBOLS=30

# News and sentiment sync
NEWS_ENABLE_RSS=true
NEWS_ENABLE_NEWSAPI=true
NEWS_ENABLE_SOCIAL_SENTIMENT=true
NEWS_SYNC_INTERVAL_MS=900000
NEWS_SYNC_LOOKBACK_DAYS=2
NEWS_SYNC_LIMIT_PER_SOURCE=50
NEWS_SENTIMENT_SYNC_INTERVAL_MS=1800000
NEWS_SENTIMENT_LOOKBACK_HOURS=72
NEWS_SENTIMENT_BATCH_LIMIT=1000
NEWS_SENTIMENT_MODEL=lexical
NEWS_FINBERT_ENDPOINT=
NEWSAPI_KEY=

khush

